server {
    listen              80;

    server_name tfsm00.ddns.net www.tfsm00.ddns.net;
    server_tokens off;
    location / {
        proxy_pass http://app:5000;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Prefix /;
    }

    location / {
        return 301 https://tfsm00.ddns.net$request_uri;
    }
}

server {
    listen 443 default_server ssl http2;

    server_name tfsm00.ddns.net;

    ssl_certificate /etc/nginx/ssl/live/tfsm00.ddns.net/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/live/tfsm00.ddns.net/privkey.pem;

    location / {
        proxy_pass http://app:5000;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Prefix /;
    }
}

